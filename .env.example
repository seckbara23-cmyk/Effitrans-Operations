# Effitrans Operations Platform — environment contract
# -----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in real values locally.
# NEVER commit real secrets. `.gitignore` ignores .env and .env.* except this file.
# Scope: Wave 0 (S0-INF-1) — foundation only. No business/auth/RLS values here yet.
# -----------------------------------------------------------------------------

# --- Supabase (DEC-A06: platform approved; region provisional per BLK-9) ------
# Project URL — Supabase dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous (publishable) key — Project Settings > API > Project API keys > anon
# Safe to expose to the browser; RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Project Settings > API > Project API keys > service_role
# SERVER ONLY. Bypasses RLS. Must never reach the client bundle or be committed.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string — Project Settings > Database > Connection string
# Used by the migration tooling (wired later in S0-DB-4). Server only.
DATABASE_URL=

# --- Communications Hub (Phase 1.14) -----------------------------------------
# Outbound email is QUEUE-FIRST with a NO-OP provider by default (messages are
# rendered + stored + marked SENT, nothing actually leaves). Wire a real provider
# only with approval. Server only.
#   COMMUNICATIONS_EMAIL_PROVIDER = (unset) | smtp | resend   -> selects provider
#   COMMUNICATIONS_EMAIL_DEBUG    = true                       -> log no-op sends
COMMUNICATIONS_EMAIL_PROVIDER=
COMMUNICATIONS_EMAIL_DEBUG=
# Resend delivery (Phase 1.18, C3) — used only when PROVIDER=resend. No SDK; the
# provider calls the Resend HTTPS API directly. FROM must be a verified sender.
#   RESEND_API_KEY            = re_...   (Resend dashboard > API Keys)
#   COMMUNICATIONS_EMAIL_FROM = "Effitrans <ops@your-domain>"
RESEND_API_KEY=
COMMUNICATIONS_EMAIL_FROM=
# Public base URL used to build portal links inside emails (e.g. https://app.effitrans...).
NEXT_PUBLIC_SITE_URL=

# --- Client portal temporary-password onboarding (Phase 3.2B) ----------------
# Portal accounts are created by an admin with a TEMPORARY PASSWORD shown once,
# shared out-of-band (phone / WhatsApp / printed) and changed at first login.
# The optional "Envoyer les identifiants par e-mail" checkbox NEVER includes the
# password unless this flag is "true" AND the admin explicitly opts in. Preferred:
# leave false (do not email passwords at all). Default: false.
PORTAL_ALLOW_PASSWORD_EMAIL=false

# --- Client portal business contact (Phase 3.3A) -----------------------------
# Shown to portal clients as the assigned-officer contact. Business (shared)
# channels ONLY — never a staff member's personal email/phone. Leave empty to
# show "Via votre espace Effitrans" and route the contact action to the portal.
#   PORTAL_CONTACT_EMAIL = operations@your-domain
#   PORTAL_CONTACT_PHONE = +221 33 000 00 00
PORTAL_CONTACT_EMAIL=
PORTAL_CONTACT_PHONE=

# --- Error monitoring (Phase 1.18, C1) ---------------------------------------
# OFF by default — the app logs structured "[observe]" lines regardless. Set a
# DSN (and wire the Sentry SDK per docs/monitoring-verification.md) to forward.
#   NEXT_PUBLIC_SENTRY_DSN = https://...  (client + browser capture; public)
#   SENTRY_DSN             = https://...  (server/edge capture; server only)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --- Notifications (Phase 1.6, DEC-B20) --------------------------------------
# In-app notifications always work. This flag only toggles the email DISPATCH
# STUB: when "true" the hook logs that it *would* email (no provider is wired
# yet). Leave unset/false until a real email provider is integrated. Server only.
NOTIFICATIONS_EMAIL_ENABLED=

# --- Online payments (Phase 1.15B) ------------------------------------------
# DARK BY DEFAULT. With PAYMENTS_ENABLED unset, online payments are off and only
# the MOCK provider exists (for dev/test). A provider is usable only when it is
# BOTH enabled (PAYMENTS_PROVIDERS) AND fully configured (its secrets present);
# a missing secret degrades that provider to "not configured" — never a crash.
# All SERVER ONLY (never NEXT_PUBLIC_).
#   PAYMENTS_ENABLED              = true            -> master switch for online pay
#   PAYMENTS_PROVIDERS            = MOCK,WAVE,ORANGE_MONEY  (CSV; default: MOCK)
#   PAYMENTS_INTENT_TTL_MINUTES   = 30              -> checkout intent lifetime
#   PAYMENTS_WEBHOOK_SKEW_MINUTES = 15              -> webhook replay-skew window
PAYMENTS_ENABLED=
PAYMENTS_PROVIDERS=
PAYMENTS_INTENT_TTL_MINUTES=
PAYMENTS_WEBHOOK_SKEW_MINUTES=
# MOCK provider (dev/test only) — needs its webhook secret to be "configured".
PAYMENTS_MOCK_WEBHOOK_SECRET=
# Wave — required only if WAVE is in PAYMENTS_PROVIDERS.
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
# Orange Money — required only if ORANGE_MONEY is in PAYMENTS_PROVIDERS.
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=

# --- Operations Copilot (Phase 3.1A) -----------------------------------------
# Read-only AI assistant on the dossier page. DARK BY DEFAULT: with no API key
# the Copilot route returns HTTP 503 with a specific "clé API absente" diagnostic
# and nothing is sent. SERVER ONLY (never NEXT_PUBLIC_) — the key bypasses no RLS
# but must never reach the client bundle. In Vercel, set OPENAI_API_KEY for the
# PRODUCTION environment (not only Preview/Development) and redeploy.
# Verify at runtime: GET /api/copilot returns { configured, apiKeyPresent, model,
# provider } — no secret. Failures return a distinct { code }.
#   OPENAI_API_KEY        = sk-...          (OpenAI dashboard > API keys)
#   OPENAI_COPILOT_MODEL  = gpt-4o-mini     (optional; defaults to gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_COPILOT_MODEL=

# --- Provider-neutral AI (Phase 3.4F-1) --------------------------------------
# The Copilot's model backend is now provider-neutral (OpenAI / Ollama / vLLM).
# BACKWARD COMPATIBLE: with AI_PROVIDER unset, the above OPENAI_* vars drive an
# OpenAI backend exactly as before — no behaviour change. Switching provider is
# configuration, not a rewrite. All SERVER ONLY (never NEXT_PUBLIC_).
#   AI_PROVIDER  = openai | ollama | vllm     (default: openai)
#   AI_MODEL     = model name                 (required for ollama/vllm; supplied,
#                                              never hard-coded — see model policy)
#   AI_BASE_URL  = provider API base          (openai: optional; vllm: required;
#                                              ollama: default http://127.0.0.1:11434)
#   AI_API_KEY   = key / bearer token         (falls back to OPENAI_API_KEY for openai)
AI_PROVIDER=
AI_MODEL=
AI_BASE_URL=
AI_API_KEY=
# Generic request timeout (ms) — the middle layer under provider-specific overrides.
AI_REQUEST_TIMEOUT_MS=
#
# --- Ollama (local Qwen) provider-specific overrides -------------------------
# Layered ABOVE the generic AI_* config: OLLAMA_* -> AI_* -> safe defaults.
# SERVER ONLY (never NEXT_PUBLIC_ — the browser must not learn the Ollama URL).
#   OLLAMA_BASE_URL           default http://127.0.0.1:11434
#   OLLAMA_MODEL              default qwen3:8b
#   OLLAMA_REQUEST_TIMEOUT_MS default 120000 (local models are slower to respond)
# Local pilot example (Ollama running on the SAME machine as `next dev`):
#   AI_PROVIDER=ollama
#   AI_LOCAL_PROVIDER_ENABLED=true
#   OLLAMA_BASE_URL=http://127.0.0.1:11434
#   OLLAMA_MODEL=qwen3:8b
#   OLLAMA_REQUEST_TIMEOUT_MS=120000
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_REQUEST_TIMEOUT_MS=
# CPU-performance / behaviour options (Ollama only):
#   OLLAMA_THINKING          default false -> suppress Qwen "thinking" (faster, concise)
#   OLLAMA_NUM_PREDICT       default 512   -> cap answer tokens for concise replies
#   OLLAMA_RETRY_ON_TIMEOUT  default false -> do NOT retry a timeout (CPU retries double the wait)
OLLAMA_THINKING=
OLLAMA_NUM_PREDICT=
OLLAMA_RETRY_ON_TIMEOUT=
# Private vLLM (Qwen/Llama) production example:
#   AI_PROVIDER=vllm
#   AI_MODEL=<approved-qwen-model>
#   AI_BASE_URL=https://ai.effitrans.sn/v1
#   AI_API_KEY=<private-server-token>
#
# Flags. Master unset => enabled (existing prod unchanged); "false" disables.
# Local providers (ollama/vllm) are DARK BY DEFAULT — opt in explicitly.
AI_COPILOT_ENABLED=
AI_LOCAL_PROVIDER_ENABLED=false
# Optional EXPLICIT fallback (never a silent paid fallback — only used if set).
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=
AI_FALLBACK_BASE_URL=
AI_FALLBACK_API_KEY=
# Production safety (enforced only when hosted, i.e. VERCEL=1):
#   AI_BASE_URL_ALLOWLIST = host1,host2   -> restrict AI_BASE_URL host in prod
#   AI_ALLOW_INSECURE_HTTP = true         -> approve a plain-HTTP remote endpoint
#   AI_ALLOW_NO_AUTH       = true         -> approve an unauthenticated internal endpoint
AI_BASE_URL_ALLOWLIST=
AI_ALLOW_INSECURE_HTTP=
AI_ALLOW_NO_AUTH=

# --- Real-time operations tracking (Phase 3.4) -------------------------------
# DARK BY DEFAULT. With TRACKING_ENABLED unset/false the whole tracking layer is
# off: the lifecycle-based portal/dossier is unchanged and nothing reads/writes
# the tracking tables. Each sub-capability additionally requires the master flag
# (a sub-flag alone does nothing). All SERVER ONLY (never NEXT_PUBLIC_) — resolved
# in lib/tracking/config.ts (pure gate in lib/tracking/flags.ts). Enable in the
# spec's rollout order: master → manual → driver → portal → wider.
#   TRACKING_ENABLED                = true   -> master switch (manual ops updates)
#   DRIVER_MOBILE_TRACKING_ENABLED  = true   -> driver mobile location sharing
#   PORTAL_LIVE_TRACKING_ENABLED    = true   -> customer-facing live map/position
#   TRACKING_REALTIME_ENABLED       = true   -> Supabase Realtime push (else poll)
#   TRACKING_GEOFENCE_ENABLED       = true   -> geofence arrival events
TRACKING_ENABLED=false
DRIVER_MOBILE_TRACKING_ENABLED=false
PORTAL_LIVE_TRACKING_ENABLED=false
TRACKING_REALTIME_ENABLED=false
TRACKING_GEOFENCE_ENABLED=false

# --- Map tiles (Phase 7.2B) ---------------------------------------------------
# Leaflet tile template for the shipment maps. PUBLIC (reaches the browser).
# Default: OpenStreetMap's standard tile server. Point at a commercial tile
# provider for production traffic volumes / SLA.
NEXT_PUBLIC_MAP_TILE_URL=

# --- 26-step process engine (Phase 5.0B+) — DARK BY DEFAULT -------------------
# Master + sub-flags (a sub-flag alone does nothing). Resolved in
# lib/process/flags.ts (pure). All SERVER ONLY.
#   EFFITRANS_PROCESS_ENGINE_ENABLED            = true -> master switch
#   EFFITRANS_PROCESS_COMPATIBILITY_ENABLED     = true -> legacy-dossier bridge
#   EFFITRANS_PROCESS_OVERRIDE_ENABLED          = true -> supervised overrides
#   EFFITRANS_PROCESS_WORKSPACES_ENABLED        = true -> Mon Travail workspaces
#   EFFITRANS_PHYSICAL_INVOICE_DEPOSIT_ENABLED  = true -> steps 23/25 deposit flow
#   EFFITRANS_COLLECTIONS_ENABLED               = true -> collections workspace
#   EFFITRANS_SHARE_DRIVER_PHONE                = true -> share driver phone with
#                                                        clients (default: NEVER)
#   EFFITRANS_PROCESS_STRUCTURES_ENABLED        = true -> Phase 9.0B workflow
#                                                        structures (owner/decision/
#                                                        blocker/team/skip actions)
EFFITRANS_PROCESS_ENGINE_ENABLED=false
EFFITRANS_PROCESS_COMPATIBILITY_ENABLED=false
EFFITRANS_PROCESS_OVERRIDE_ENABLED=false
EFFITRANS_PROCESS_WORKSPACES_ENABLED=false
EFFITRANS_PHYSICAL_INVOICE_DEPOSIT_ENABLED=false
EFFITRANS_COLLECTIONS_ENABLED=false
EFFITRANS_PROCESS_STRUCTURES_ENABLED=false
EFFITRANS_SHARE_DRIVER_PHONE=false

# --- Effitrans Messaging Center (Phase 8.7) — DARK BY DEFAULT ------------------
# Global kill switch, resolved in lib/messaging/rollout.ts (SERVER ONLY). Independent
# of the process-engine flags above — messaging has no dependency on that engine. Per-
# tenant enablement is a SEPARATE toggle at /platform/rollout (public.tenant_messaging_
# rollout), gated behind this env var being true first.
#   EFFITRANS_MESSAGING_CENTER_ENABLED = true -> master switch
EFFITRANS_MESSAGING_CENTER_ENABLED=false

# --- Copilot rate limits (Phases 7.6B/7.6C/7.7) — all optional, safe defaults --
# Counted over the append-only audit log (no extra table). Over-limit requests
# degrade to the deterministic summary — never a hard failure. SERVER ONLY.
#   COPILOT_USER_RATE_PER_MIN             default 12   (staff logistics copilot)
#   COPILOT_TENANT_RATE_PER_DAY           default 2000
#   PORTAL_COPILOT_USER_RATE_PER_MIN      default 6    (customer AI assistant)
#   PORTAL_COPILOT_TENANT_RATE_PER_DAY    default 1000
#   EXECUTIVE_COPILOT_USER_RATE_PER_MIN   default 12   (executive assistant)
#   EXECUTIVE_COPILOT_TENANT_RATE_PER_DAY default 1000
COPILOT_USER_RATE_PER_MIN=
COPILOT_TENANT_RATE_PER_DAY=
PORTAL_COPILOT_USER_RATE_PER_MIN=
PORTAL_COPILOT_TENANT_RATE_PER_DAY=
EXECUTIVE_COPILOT_USER_RATE_PER_MIN=
EXECUTIVE_COPILOT_TENANT_RATE_PER_DAY=

# -----------------------------------------------------------------------------
# Deferred (do NOT set in Wave 0 — listed so the contract is complete):
#   Email/SMS providers  -> Wave 3+ (notifications, S9)
#   WhatsApp BSP         -> Phase 2 (BLK-5)
# -----------------------------------------------------------------------------
