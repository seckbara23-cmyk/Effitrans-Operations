# Effitrans Operations Platform — environment contract
# -----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in real values locally.
# NEVER commit real secrets. `.gitignore` ignores .env and .env.* except this file.
# Scope: Wave 0 (S0-INF-1) — foundation only. No business/auth/RLS values here yet.
# -----------------------------------------------------------------------------

# --- Supabase (DEC-A06: platform approved; region provisional per BLK-9) ------
# Project URL — Supabase dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous (publishable) key — Project Settings > API > Project API keys > anon
# Safe to expose to the browser; RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Project Settings > API > Project API keys > service_role
# SERVER ONLY. Bypasses RLS. Must never reach the client bundle or be committed.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string — Project Settings > Database > Connection string
# Used by the migration tooling (wired later in S0-DB-4). Server only.
DATABASE_URL=

# --- Communications Hub (Phase 1.14) -----------------------------------------
# Outbound email is QUEUE-FIRST with a NO-OP provider by default (messages are
# rendered + stored + marked SENT, nothing actually leaves). Wire a real provider
# only with approval. Server only.
#   COMMUNICATIONS_EMAIL_PROVIDER = (unset) | smtp | resend   -> selects provider
#   COMMUNICATIONS_EMAIL_DEBUG    = true                       -> log no-op sends
COMMUNICATIONS_EMAIL_PROVIDER=
COMMUNICATIONS_EMAIL_DEBUG=
# Public base URL used to build portal links inside emails (e.g. https://app.effitrans...).
NEXT_PUBLIC_SITE_URL=

# --- Notifications (Phase 1.6, DEC-B20) --------------------------------------
# In-app notifications always work. This flag only toggles the email DISPATCH
# STUB: when "true" the hook logs that it *would* email (no provider is wired
# yet). Leave unset/false until a real email provider is integrated. Server only.
NOTIFICATIONS_EMAIL_ENABLED=

# -----------------------------------------------------------------------------
# Deferred (do NOT set in Wave 0 — listed so the contract is complete):
#   Email/SMS providers  -> Wave 3+ (notifications, S9)
#   WhatsApp BSP         -> Phase 2 (BLK-5)
# -----------------------------------------------------------------------------
